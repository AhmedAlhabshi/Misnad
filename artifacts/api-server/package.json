{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps --env-file=.env ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx src/routes/__tests__/analyzeContract.validation.test.ts && tsx src/routes/__tests__/analyzeContract.validType.test.ts && tsx src/routes/__tests__/analyzeContract.financialMetrics.test.ts && tsx src/services/__tests__/documentParser.test.ts && tsx src/services/__tests__/piiMasker.test.ts && tsx src/routes/__tests__/analyzeContract.documentExtraction.test.ts && tsx src/routes/__tests__/analyzeContract.financialRecoveryFixture.test.ts",
    "test:dist": "pnpm run build && tsx src/services/__tests__/tesseractWorkerPath.dist.test.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "1.0.2",
    "@workspace/api-zod": "workspace:*",
    "@workspace/contract-analysis": "workspace:*",
    "@workspace/contract-schema": "workspace:*",
    "@workspace/contract-types": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/document-ocr": "workspace:*",
    "@workspace/financial-metrics": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "pdf-parse": "^1.1.4",
    "pdfjs-dist": "6.1.200",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "tesseract.js": "7.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "catalog:",
    "@types/pdf-parse": "^1.1.5",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
