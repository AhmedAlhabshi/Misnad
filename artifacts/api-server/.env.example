# Copy this file to `.env` in this same directory and fill in real values.
# Never commit `.env` — it is git-ignored (see the repository's .gitignore).
# Every value below is a placeholder/example only. No real keys or credentials.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Port the API server listens on. Required.
PORT=3000

# development | production. Optional — affects logging only.
NODE_ENV=development

# pino log level: fatal | error | warn | info | debug | trace | silent. Optional.
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Database (PostgreSQL with the pgvector extension enabled)
# ---------------------------------------------------------------------------

# Required. Used by Legal RAG and Contract RAG for storage/retrieval.
DATABASE_URL=postgresql://user:password@localhost:5432/misnad

# Optional — only needed by drizzle-kit for schema migrations if it must
# bypass a pooled connection string used by DATABASE_URL.
# DIRECT_DATABASE_URL=postgresql://user:password@localhost:5432/misnad

# ---------------------------------------------------------------------------
# Google Gemini (primary AI provider)
# ---------------------------------------------------------------------------

# Comma-separated list of Gemini API keys, used for key rotation. Preferred
# over GEMINI_API_KEY below when both are set. Required (or set GEMINI_API_KEY).
GEMINI_API_KEYS=your-gemini-api-key-1,your-gemini-api-key-2

# Single-key fallback, used only if GEMINI_API_KEYS is not set. Kept for
# backward compatibility with single-key setups.
# GEMINI_API_KEY=your-gemini-api-key

# Gemini model id used for contract analysis, personalized analysis, and
# chat answer composition. Optional — defaults to "gemini-2.5-flash".
GEMINI_MODEL=gemini-2.5-flash

# Gemini embedding model id used by Legal RAG / Contract RAG. Optional —
# defaults to "gemini-embedding-001".
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Seconds a rate-limited/unavailable Gemini key is skipped before it is
# retried again. Optional — defaults to 120.
GEMINI_KEY_COOLDOWN_SECONDS=120

# Per-key timeout (ms) for a single Gemini call before it is abandoned and
# rotated past, without waiting for a hung response. Optional — defaults to
# 10000 (10 seconds).
GEMINI_ATTEMPT_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# OpenRouter (fallback AI provider, used only when Gemini is rate-limited or
# unavailable)
# ---------------------------------------------------------------------------

OPENROUTER_API_KEY=your-openrouter-api-key

# OpenRouter model id used for the fallback path. Optional — defaults to
# "qwen/qwen3-next-80b-a3b-instruct:free".
# OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# ---------------------------------------------------------------------------
# OCR tuning (all optional — safe built-in defaults are used if unset)
# ---------------------------------------------------------------------------

# OCR_ENABLED=true
# OCR_MAX_PAGES=30
# OCR_TIMEOUT_MS=120000
# OCR_PAGE_TIMEOUT_MS=30000
# OCR_PAGE_CONCURRENCY=1
# OCR_LANGUAGES=ara+eng
# OCR_RENDER_DPI=300
# OCR_RENDER_SCALE takes precedence over OCR_RENDER_DPI if both are set —
# set at most one. Default render resolution is 300 DPI (scale 300/72).
# OCR_RENDER_SCALE=4.17
# OCR_PREPROCESSING_ENABLED=false

# ---------------------------------------------------------------------------
# Contract RAG tuning (all optional — safe built-in defaults are used if unset)
# ---------------------------------------------------------------------------

# CONTRACT_RAG_TTL_MINUTES=120
# CONTRACT_RAG_MAX_INDEXED_CHARS=200000
# CONTRACT_RAG_MAX_CHUNKS_PER_CONTRACT=400
# CONTRACT_RAG_MAX_CHUNK_CHARS=2000
# CONTRACT_RAG_MAX_QUERY_CHARS=500
# CONTRACT_RAG_MAX_TOP_K=10
# CONTRACT_RAG_MAX_EXCERPT_CHARS=600
# CONTRACT_RAG_MAX_TOTAL_CONTEXT_CHARS=6000
# CONTRACT_RAG_MIN_RELEVANCE_SCORE=0.12
